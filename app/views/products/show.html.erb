
<h1><%= @product.name %></h1>
<%= link_to 'Login', new_session_path unless authenticated? %>
 <%= link_to 'Back', products_path %>

<% if authenticated?%>
 <%= link_to 'Edit', edit_product_path(@product) %>
 <%= button_to "Delete", @product, method: :delete, data: {turbo_confirm: "Are you ready to delete, sure?"} %>
 <%end%>